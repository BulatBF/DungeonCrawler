{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/DungeonCrawler/DungeonCrawler.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile",
            "group": { "kind": "build", "isDefault": true }
        },
        {
            "label": "publish (без .NET)",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/DungeonCrawler/DungeonCrawler.csproj",
                "-c", "Release",
                "-r", "win-x64",
                "--self-contained", "false",
                "-p:PublishSingleFile=true"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish (со встроенным .NET)",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/DungeonCrawler/DungeonCrawler.csproj",
                "-c", "Release",
                "-r", "win-x64",
                "--self-contained", "true",
                "-p:PublishSingleFile=true"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}